-- ─────────────────────────────────────────────────────────────
-- WebSocket class
-- ─────────────────────────────────────────────────────────────
do
	local WebSocket = {}
	WebSocket.__index = WebSocket

	local function makeSignal()
		local callbacks = {}
		local signal = {}
		function signal:Connect(cb)
			assert(type(cb) == "function", "Connect expects a function")
			local id = #callbacks + 1
			callbacks[id] = cb
			local conn = {}
			function conn:Disconnect()
				callbacks[id] = nil
			end
			conn.disconnect = conn.Disconnect
			return conn
		end
		signal.connect = signal.Connect
		function signal:_fire(...)
			for _, cb in pairs(callbacks) do
				task.spawn(cb, ...)
			end
		end
		return signal
	end

	function WebSocket.connect(url)
		assert(type(url) == "string", "invalid argument #1 to 'WebSocket.connect' (string expected, got " .. type(url) .. ")", 2)
		assert(url:match("^wss?://"), "invalid argument #1 to 'WebSocket.connect' (WebSocket URL must start with ws:// or wss://)", 2)

		local token = hs:GenerateGUID(false)
		local result = nukedata("", "ws_connect", { token = token, url = url })
		if result ~= "ok" then
			error("WebSocket.connect: Encountered an error while trying to connect to the websocket: " .. tostring(result), 2)
		end

		local self = setmetatable({}, WebSocket)
		self._token    = token
		self._closed   = false
		self.OnMessage = makeSignal()
		self.OnClose   = makeSignal()

		task.spawn(function()
			while not self._closed do
				local raw = nukedata("", "ws_recv", { token = token })
				if raw == "__CLOSED__" then
					self._closed = true
					self.OnClose:_fire()
					break
				elseif raw and #raw > 0 then
					for encoded in raw:gmatch("[^\n]+") do
						local ok, msg = pcall(env.base64decode, encoded)
						if ok and msg then
							self.OnMessage:_fire(msg)
						end
					end
				end
				task.wait(0.05)
			end
		end)

		return self
	end

	function WebSocket:Send(message)
		assert(type(message) == "string", "invalid argument #1 to 'WebSocket:Send' (string expected, got " .. type(message) .. ")", 2)
		assert(not self._closed, "WebSocket:Send called on a closed WebSocket", 2)
		nukedata(message, "ws_send", { token = self._token })
	end

	function WebSocket:Close()
		if self._closed then return end
		self._closed = true
		nukedata("", "ws_close", { token = self._token })
		self.OnClose:_fire()
	end

	env.WebSocket = WebSocket
end

