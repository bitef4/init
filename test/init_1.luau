local function checkExtension(filepath, funcname)
	local lower = filepath:lower()
	for _, ext in ipairs(blocked_extensions) do
		if lower:sub(-#ext) == ext then
			error(funcname .. ": blocked file extension: " .. ext, 3)
		end
	end
end

