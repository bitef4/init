	if env.iscclosure(func) then
		return debug.info(func, 'n') == ""
	end
	local success, fenv = pcall(getfenv, func)
	if not success then return false end
	if typeof(fenv.script) ~= "Instance" then return true end
	if fenv.script.Name == "AvatarEditorPrompts" or fenv.script.Name == "JestGlobals" then return false end
	if fenv.script.Parent == nil then return true end
	if fenv == getfenv(0) then return true end
	return true
end
